{
  "title": "Resilient AI Pipeline - Visão Geral",
  "uid": "pipeline-dashboard",
  "tags": [
    "pipeline",
    "observability"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "panels": [
    {
      "type": "logs",
      "title": "Logs em Tempo Real (Todos os Workers)",
      "gridPos": {
        "h": 15,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{service_name=~\"gateway|transcription-worker|cleaning-worker|insights-.*\"} | json"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "timeseries",
      "title": "Volume de Requisições HTTP (Gateway)",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{service_name=\"gateway\"}[1m])) by (http_route)",
          "legendFormat": "{{http_route}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Latência HTTP do Gateway (ms)",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket{service_name=\"gateway\"}[1m])) by (le))",
          "legendFormat": "p95 latency"
        }
      ]
    }
  ]
}
