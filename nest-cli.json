{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/gateway/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "apps/gateway/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/gateway",
  "projects": {
    "gateway": {
      "type": "application",
      "root": "apps/gateway",
      "entryFile": "main",
      "sourceRoot": "apps/gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/gateway/tsconfig.app.json"
      }
    },
    "transcription-worker": {
      "type": "application",
      "root": "apps/transcription-worker",
      "entryFile": "main",
      "sourceRoot": "apps/transcription-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/transcription-worker/tsconfig.app.json"
      }
    },
    "cleaning-worker": {
      "type": "application",
      "root": "apps/cleaning-worker",
      "entryFile": "main",
      "sourceRoot": "apps/cleaning-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/cleaning-worker/tsconfig.app.json"
      }
    },
    "insights-summary-worker": {
      "type": "application",
      "root": "apps/insights-summary-worker",
      "entryFile": "main",
      "sourceRoot": "apps/insights-summary-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/insights-summary-worker/tsconfig.app.json"
      }
    },
    "insights-deadlines-worker": {
      "type": "application",
      "root": "apps/insights-deadlines-worker",
      "entryFile": "main",
      "sourceRoot": "apps/insights-deadlines-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/insights-deadlines-worker/tsconfig.app.json"
      }
    },
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.lib.json"
      }
    }
  }
}